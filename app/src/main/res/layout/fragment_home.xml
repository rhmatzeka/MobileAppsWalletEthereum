<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeSwipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="140dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_greeting"
                android:textColor="@color/mw_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/home_overview"
                android:textColor="@color/mw_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textNetworkBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_surface"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="@string/network_sepolia"
                android:textColor="@color/mw_highlight"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/balanceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/balance_label"
                    android:textColor="@color/mw_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/textEthBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/sample_eth_balance"
                    android:textColor="@color/mw_text_primary"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textFiatBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/sample_fiat_balance"
                    android:textColor="@color/mw_text_secondary"
                    android:textSize="15sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_divider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/wallet_address_label"
                            android:textColor="@color/mw_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/textWalletAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/sample_wallet_address"
                            android:textColor="@color/mw_text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonCopyAddress"
                        style="@style/Widget.MatsWallet.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:minWidth="0dp"
                        android:text="@string/copy_action" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonShowQr"
                        style="@style/Widget.MatsWallet.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:text="@string/qr_action" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSend"
                    style="@style/Widget.MatsWallet.Button.Tonal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:minLines="1"
                    android:paddingHorizontal="8dp"
                    android:textSize="12sp"
                    android:text="@string/send_action" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonReceive"
                    style="@style/Widget.MatsWallet.Button.Tonal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:minLines="1"
                    android:paddingHorizontal="8dp"
                    android:textSize="12sp"
                    android:text="@string/receive_action" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonBuy"
                    style="@style/Widget.MatsWallet.Button.Tonal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:minLines="1"
                    android:paddingHorizontal="8dp"
                    android:textSize="12sp"
                    android:text="@string/buy_action" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonRefresh"
                    style="@style/Widget.MatsWallet.Button.Tonal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:minLines="1"
                    android:paddingHorizontal="8dp"
                    android:textSize="12sp"
                    android:text="@string/refresh_action" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_trust_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/trust_card_title"
                    android:textColor="@color/mw_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/trust_card_subtitle"
                    android:textColor="@color/mw_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_surface_elevated"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:text="@string/trust_badge_keystore"
                        android:textColor="@color/mw_highlight"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_surface_elevated"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:text="@string/trust_badge_gas"
                        android:textColor="@color/mw_highlight"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_surface_elevated"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:text="@string/trust_badge_testnet"
                        android:textColor="@color/mw_highlight"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card_surface"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/eth_chart_title"
                    android:textColor="@color/mw_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/eth_chart_subtitle"
                    android:textColor="@color/mw_text_secondary"
                    android:textSize="13sp" />

                <com.github.mikephil.charting.charts.CandleStickChart
                    android:id="@+id/chartEthPrice"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="14dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/assetSectionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_card_surface"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/asset_section_title"
                        android:textColor="@color/mw_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/buttonAssetHistory"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_pin_key_action"
                        android:contentDescription="@string/asset_history_action"
                        android:padding="10dp"
                        android:src="@drawable/ic_history_24" />

                    <ImageButton
                        android:id="@+id/buttonAssetFilter"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_pin_key_action"
                        android:contentDescription="@string/asset_filter_action"
                        android:padding="10dp"
                        android:src="@drawable/ic_filter_24" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/assetTabs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/tabCrypto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textTabCrypto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/asset_tab_crypto"
                            android:textColor="@color/mw_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <View
                            android:id="@+id/indicatorTabCrypto"
                            android:layout_width="72dp"
                            android:layout_height="4dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_asset_tab_indicator" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tabWatchlist"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textTabWatchlist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/asset_tab_watchlist"
                            android:textColor="@color/mw_text_secondary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <View
                            android:id="@+id/indicatorTabWatchlist"
                            android:layout_width="72dp"
                            android:layout_height="4dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_asset_tab_indicator"
                            android:visibility="invisible" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tabNfts"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textTabNfts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/asset_tab_nfts"
                            android:textColor="@color/mw_text_secondary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <View
                            android:id="@+id/indicatorTabNfts"
                            android:layout_width="72dp"
                            android:layout_height="4dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_asset_tab_indicator"
                            android:visibility="invisible" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_divider" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerTokens"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_token" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerNfts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_nft" />

                <LinearLayout
                    android:id="@+id/layoutNftEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_card_surface_elevated"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/nft_empty_title"
                        android:textColor="@color/mw_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/nft_empty_subtitle"
                        android:textColor="@color/mw_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutWatchlistEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_card_surface_elevated"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/watchlist_empty_title"
                        android:textColor="@color/mw_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/watchlist_empty_subtitle"
                        android:textColor="@color/mw_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_promo_banner"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/promo_title"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/promo_subtitle"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonPromo"
                    style="@style/Widget.MatsWallet.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/promo_button" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
