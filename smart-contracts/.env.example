INFURA_PROJECT_ID=your_infura_project_id
DEPLOYER_PRIVATE_KEY=your_private_key_without_0x
TOKEN_NAME=Mats Token
TOKEN_SYMBOL=MATS
TOKEN_INITIAL_SUPPLY=1000000
MATS_TOKEN_ADDRESS=your_existing_mats_token_address
MATS_SWAP_POOL_ADDRESS=your_swap_pool_address
IDRX_TOKEN_ADDRESS=your_existing_idrx_token_address
IDRX_SWAP_POOL_ADDRESS=your_idrx_swap_pool_address
POOL_TOKEN_SYMBOL=MATS
POOL_TOKEN_ADDRESS=your_token_address_for_generic_pool_deploy_or_seed
POOL_SWAP_ADDRESS=your_swap_pool_address_for_generic_seed
POOL_TOKEN_LIQUIDITY=10000
POOL_ETH_LIQUIDITY=0.5
TEST_SWAP_TOKENS=MATS,IDRX,USDT,USDC,DAI,WBTC,LINK,UNI,AAVE,SHIB,PEPE,ARB,OP
TEST_POOL_ETH_LIQUIDITY=0.005
# Optional per-token override for the bulk testnet deploy script:
# TEST_USDT_TOKEN_LIQUIDITY=100000

# Optional buy backend for Android "Beli" flow.
# Never put these secrets inside Android local.properties.
BUY_SERVER_PORT=8787
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key_optional
MIDTRANS_IS_PRODUCTION=false
BUY_TREASURY_PRIVATE_KEY=private_key_that_funds_testnet_buys_without_0x
BUY_RPC_URL=
BUY_ASSET=ETH
BUY_MIN_IDR=1000
# Harga buy dihitung realtime server-side dari CoinGecko, lalu fallback realtime Indodax ETH/IDR.
BUY_SPREAD_PERCENT=0
BUY_ALLOW_TEST_SETTLE=false
BUY_DEV_MODE=true
