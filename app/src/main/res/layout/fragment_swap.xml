<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swapRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mw_secondary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="124dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textSwapNetworkBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_swap_top_chip"
                android:paddingHorizontal="10dp"
                android:paddingVertical="7dp"
                android:text="@string/network_sepolia"
                android:textColor="@color/mw_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/swap_screen_title"
                android:textColor="@color/mw_text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textSwapSlippage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_swap_top_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="7dp"
                android:text="@string/swap_slippage_badge"
                android:textColor="@color/mw_text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/swap_screen_subtitle"
            android:textColor="@color/mw_text_secondary"
            android:textSize="12sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_swap_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/swap_from_label"
                        android:textColor="@color/mw_text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/cardSwapFromAsset"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imageSwapFromIcon"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:src="@drawable/ic_token_mats" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/textSwapFromSymbol"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="MATS"
                                    android:textColor="@color/mw_text_primary"
                                    android:textSize="20sp"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="8dp"
                                    android:src="@drawable/ic_chevron_right_24"
                                    android:tint="@color/mw_text_secondary" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/textSwapFromName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Mats Token"
                                android:textColor="@color/mw_text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="98dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">

                            <EditText
                                android:id="@+id/inputSwapAmount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:gravity="end"
                                android:hint="@string/swap_amount_hint"
                                android:inputType="numberDecimal"
                                android:maxLines="1"
                                android:textColor="@color/mw_text_primary"
                                android:textColorHint="@color/mw_text_secondary"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textSwapFromMeta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:text="@string/swap_input_caption"
                                android:textColor="@color/mw_text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_swap_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/swap_to_label"
                        android:textColor="@color/mw_text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/cardSwapToAsset"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imageSwapToIcon"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:src="@drawable/ic_token_eth_real" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/textSwapToSymbol"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ETH"
                                    android:textColor="@color/mw_text_primary"
                                    android:textSize="20sp"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="8dp"
                                    android:src="@drawable/ic_chevron_right_24"
                                    android:tint="@color/mw_text_secondary" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/textSwapToName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Ethereum"
                                android:textColor="@color/mw_text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="110dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/textSwapQuote"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:text="0"
                                android:textColor="@color/mw_text_primary"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textSwapQuoteMeta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:text="@string/swap_quote_placeholder"
                                android:textColor="@color/mw_text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <ImageButton
                android:id="@+id/buttonSwapDirection"
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_swap_switch_button"
                android:contentDescription="@string/swap_direction_label"
                android:padding="18dp"
                android:src="@drawable/ic_swap_24" />
        </FrameLayout>

        <TextView
            android:id="@+id/textSwapNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_surface"
            android:padding="12dp"
            android:text="@string/swap_pool_note_placeholder"
            android:textColor="@color/mw_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textSwapStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_surface"
            android:padding="12dp"
            android:textColor="@color/mw_text_secondary"
            android:textSize="12sp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonApproveSwap"
            style="@style/Widget.MatsWallet.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/swap_approve_action_placeholder"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonExecuteSwap"
            style="@style/Widget.MatsWallet.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="@string/continue_action"
            android:textColor="@color/black"
            android:textSize="17sp"
            android:textStyle="bold"
            app:backgroundTint="@color/mw_highlight" />
    </LinearLayout>
</ScrollView>
