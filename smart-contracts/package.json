{
  "name": "mats-wallet-contracts",
  "version": "1.0.0",
  "private": true,
  "description": "Smart contracts for Mats Wallet (Sepolia).",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:token": "hardhat run scripts/deploy.js --network sepolia",
