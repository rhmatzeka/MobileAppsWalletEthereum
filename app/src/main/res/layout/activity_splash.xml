<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:padding="24dp">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="42dp"
        android:layout_marginEnd="-42dp"
        android:alpha="0.42"
        android:background="@drawable/bg_splash_orb"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:layout_marginStart="-40dp"
        android:layout_marginBottom="46dp"
        android:alpha="0.22"
        android:background="@drawable/bg_splash_orb"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/splashContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/splashBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_splash_chip"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/splash_badge"
            android:textColor="@color/mw_text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="218dp"
            android:layout_height="218dp"
            android:layout_marginTop="28dp">

            <View
                android:id="@+id/viewOuterRing"
                android:layout_width="218dp"
                android:layout_height="218dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_splash_ring" />

            <View
                android:id="@+id/viewInnerRing"
                android:layout_width="164dp"
                android:layout_height="164dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_splash_ring" />

            <FrameLayout
                android:id="@+id/logoCore"
                android:layout_width="108dp"
                android:layout_height="108dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_splash_logo_core"
                android:padding="10dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/splash_logo_content_description"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ethernest1" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/splash_title"
            android:textColor="@color/mw_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/splash_subtitle"
            android:textColor="@color/mw_text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:id="@+id/dotOne"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_splash_dot" />

            <View
                android:id="@+id/dotTwo"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="10dp"
                android:alpha="0.35"
                android:background="@drawable/bg_splash_dot" />

            <View
                android:id="@+id/dotThree"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="10dp"
                android:alpha="0.35"
                android:background="@drawable/bg_splash_dot" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/splash_loading_status"
            android:textColor="@color/mw_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
