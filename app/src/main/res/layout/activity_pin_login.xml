<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/pinLoginRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:paddingHorizontal="28dp"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/pinKeyboard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.28">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/pin_login_title"
            android:textColor="@color/mw_text_primary"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="@string/pin_login_subtitle"
            android:textColor="@color/mw_text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/pinIndicatorContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/pinSlotOne"
                style="@style/Widget.MatsWallet.PinSlot" />

            <TextView
                android:id="@+id/pinSlotTwo"
                style="@style/Widget.MatsWallet.PinSlot"
                android:layout_marginStart="10dp" />

            <TextView
                android:id="@+id/pinSlotThree"
                style="@style/Widget.MatsWallet.PinSlot"
                android:layout_marginStart="10dp" />

            <TextView
                android:id="@+id/pinSlotFour"
                style="@style/Widget.MatsWallet.PinSlot"
                android:layout_marginStart="10dp" />

            <TextView
                android:id="@+id/pinSlotFive"
                style="@style/Widget.MatsWallet.PinSlot"
                android:layout_marginStart="10dp" />

            <TextView
                android:id="@+id/pinSlotSix"
                style="@style/Widget.MatsWallet.PinSlot"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/textPinMessage"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textColor="@color/mw_error"
            android:textSize="13sp" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/pinKeyboard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:alignmentMode="alignMargins"
        android:columnCount="3"
        android:rowCount="4"
        android:useDefaultMargins="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/keyOne"
            style="@style/Widget.MatsWallet.PinKey"
            android:text="1" />

        <TextView
            android:id="@+id/keyTwo"
            style="@style/Widget.MatsWallet.PinKey"
            android:text="2" />

        <TextView
            android:id="@+id/keyThree"
            style="@style/Widget.MatsWallet.PinKey"
            android:text="3" />

        <TextView
            android:id="@+id/keyFour"
            style="@style/Widget.MatsWallet.PinKey"
            android:text="4" />

        <TextView
            android:id="@+id/keyFive"
            style="@style/Widget.MatsWallet.PinKey"
            android:text="5" />

        <TextView
            android:id="@+id/keySix"
            style="@style/Widget.MatsWallet.PinKey"
            android:text="6" />

        <TextView
            android:id="@+id/keySeven"
            style="@style/Widget.MatsWallet.PinKey"
            android:text="7" />

        <TextView
            android:id="@+id/keyEight"
            style="@style/Widget.MatsWallet.PinKey"
            android:text="8" />

        <TextView
            android:id="@+id/keyNine"
            style="@style/Widget.MatsWallet.PinKey"
            android:text="9" />

        <TextView
            android:id="@+id/buttonUseBiometric"
            style="@style/Widget.MatsWallet.PinKey.Action"
            android:text="@string/pin_biometric_key" />

        <TextView
            android:id="@+id/keyZero"
            style="@style/Widget.MatsWallet.PinKey"
            android:text="0" />

        <TextView
            android:id="@+id/keyBackspace"
            style="@style/Widget.MatsWallet.PinKey.Action"
            android:text="@string/pin_backspace_key" />
    </GridLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
