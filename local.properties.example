SWAP_ARB_TOKEN_ADDRESS=
SWAP_ARB_POOL_ADDRESS=
SWAP_ARB_DECIMALS=18
SWAP_OP_TOKEN_ADDRESS=
SWAP_OP_POOL_ADDRESS=
SWAP_OP_DECIMALS=18
# Optional extra real swap routes. Custom slots appear after you fill at least
# SYMBOL/NAME or a working ADDRESS + POOL_ADDRESS.
SWAP_TOKEN_1_NAME=Example Token
SWAP_TOKEN_1_SYMBOL=EXT
SWAP_TOKEN_1_ADDRESS=your_extra_token_address
SWAP_TOKEN_1_POOL_ADDRESS=your_extra_swap_pool_address
