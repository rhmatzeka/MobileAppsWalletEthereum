<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="170dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:background="@drawable/bg_card_surface"
    android:orientation="vertical"
    android:padding="12dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="128dp"
        android:background="@drawable/bg_nft_art"
        android:padding="14dp">

        <ImageView
            android:id="@+id/imageNft"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/nft_section_title"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/textNftSymbol"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_action_circle"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/mw_highlight"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

    <TextView
        android:id="@+id/textNftName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/mw_text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textNftTokenId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/mw_text_secondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/textNftNetwork"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/mw_text_secondary"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/textNftContract"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/mw_text_secondary"
        android:textSize="11sp" />
</LinearLayout>
